# Скопируйте в .env и заполните значения.
# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=easybooker
DB_USER=easybooker
DB_PASSWORD=changeme

# Telegram Bot (от @BotFather)
BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Telegram user id администраторов (JSON-массив целых чисел)
ADMINS=[123456789]

# Публичный URL бэкенда (FastAPI + webhook), без завершающего слэша
BACK_URL=https://your-domain.example

# URL фронтенда (мини-приложение / WebApp)
FRONT_URL=https://your-frontend.example

# Redis (опционально; для кэш-слоя в app/redis_dao)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
